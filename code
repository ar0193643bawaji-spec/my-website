<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>The Pizza Shop - Lahore</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Poppins',sans-serif;background:#fff;color:#1a1a1a}
header{position:fixed;width:100%;top:0;background:#1a1a1a;color:#fff;display:flex;justify-content:space-between;align-items:center;padding:15px 30px;z-index:1000}
header h1{color:#FF7A00}
nav a{color:#fff;margin:0 12px;text-decoration:none}
.hero{height:100vh;background:url('https://images.unsplash.com/photo-1601924638867-3ec2f2e4a1b5') center/cover no-repeat;display:flex;align-items:center;justify-content:center;text-align:center;color:#fff;padding:20px}
.hero h2{font-size:50px}
.btn{background:#E63946;color:#fff;border:none;padding:12px 25px;border-radius:30px;margin:10px;cursor:pointer}
.section{padding:90px 20px;text-align:center}
.cards{display:flex;flex-wrap:wrap;gap:20px;justify-content:center}
.card{width:280px;border-radius:15px;overflow:hidden;box-shadow:0 5px 20px rgba(0,0,0,0.1);background:#fff}
.card img{width:100%;height:180px;object-fit:cover}
.menu-item{border:1px solid #ddd;padding:15px;border-radius:10px;margin:10px;max-width:400px;margin-inline:auto}
select,button.add{margin-top:8px;padding:6px;width:100%}
footer{background:#1a1a1a;color:#fff;text-align:center;padding:20px}
.cart{position:fixed;bottom:20px;right:20px;background:#FF7A00;color:#fff;padding:15px;border-radius:50px}
</style>
</head>
<body>

<header>
<h1>The Pizza Shop</h1>
<nav>
<a href="#">Home</a>
<a href="#menu">Menu</a>
<a href="#about">About</a>
<a href="#reviews">Reviews</a>
<a href="#contact">Contact</a>
</nav>
</header>

<section class="hero">
<div>
<h2>Fresh, Hot & Loaded</h2>
<p>Your Favorite Fast Food Spot in Lahore</p>
<button class="btn" onclick="document.getElementById('menu').scrollIntoView({behavior:'smooth'})">View Menu</button>
<button class="btn">Order Now</button>
</div>
</section>

<section class="section">
<h2>Quick Info</h2>
<p>📍 Barki Road Lahore | ⏰ 2PM - 2AM | 📞 0301 8408177</p>
</section>

<section class="section" id="menu">
<h2>Full Menu</h2>

<div class="menu-item">
<h3>Chicken Pizza - Rs 1200</h3>
<select><option>Small</option><option>Medium</option><option>Large</option></select>
<select><option>Extra Cheese</option><option>Extra Chicken</option></select>
<button class="add" onclick="addToCart('Chicken Pizza')">Add to Cart</button>
</div>

<div class="menu-item">
<h3>Zinger Burger - Rs 450</h3>
<select><option>Single</option><option>Combo</option></select>
<select><option>Mayo</option><option>BBQ</option><option>Spicy</option></select>
<button class="add" onclick="addToCart('Zinger Burger')">Add to Cart</button>
</div>

<div class="menu-item">
<h3>Shawarma - Rs 250</h3>
<select><option>Normal</option><option>Extra Sauce</option></select>
<button class="add" onclick="addToCart('Shawarma')">Add to Cart</button>
</div>

<div class="menu-item">
<h3>Fried Chicken - Rs 500</h3>
<select><option>2 pcs</option><option>4 pcs</option></select>
<button class="add" onclick="addToCart('Fried Chicken')">Add to Cart</button>
</div>

</section>

<section class="section" id="about">
<h2>About Us</h2>
<p>We are a Lahore-based fast food brand focused on taste, affordability, and fast service.</p>
</section>

<section class="section" id="reviews">
<h2>Reviews</h2>
<div class="cards">
<div class="card"><h3>★★★★★</h3><p>Amazing value for money!</p></div>
<div class="card"><h3>★★★★★</h3><p>Perfect budget deals!</p></div>
<div class="card"><h3>★★★★☆</h3><p>Pizza base is good.</p></div>
</div>
</section>

<section class="section" id="contact">
<h2>Contact</h2>
<p>155 Barki Rd, Lahore</p>
<p>0301 8408177</p>
<iframe src="https://maps.google.com/maps?q=lahore&t=&z=13&ie=UTF8&iwloc=&output=embed" width="100%" height="300"></iframe>
</section>

<div class="cart" id="cart">Cart (0)</div>

<footer>
<p>© 2026 The Pizza Shop</p>
</footer>

<script>
let count = 0;
function addToCart(item){
count++;
document.getElementById('cart').innerText = `Cart (${count})`;
alert(item + ' added to cart');
}
</script>

</body>
</html>
